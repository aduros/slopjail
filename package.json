{
  "name": "slopjail",
  "version": "2.0.0",
  "keywords": [
    "browser",
    "csp",
    "iframe",
    "isolation",
    "jail",
    "javascript-sandbox",
    "sandbox",
    "security",
    "untrusted-code",
    "web-worker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aduros/slopjail"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "vite build",
    "prepack": "npm run build -- --emptyOutDir",
    "release": "bump --commit --tag --push",
    "start": "vite build --watch",
    "test": "vitest run",
    "lint": "oxlint --disable-nested-config",
    "format": "oxfmt --check"
  },
  "dependencies": {
    "shrimp-rpc": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@vitest/browser-playwright": "^4.0.18",
    "lefthook": "^2.0.16",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.9.3",
    "version-bump-prompt": "^6.1.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
